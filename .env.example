# Generate with: npx web-push generate-vapid-keys --json
# Copy to .env.local with real values. On Vercel, set all three in Project Settings > Environment Variables.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: or https: URL identifying the app owner (required by the Web Push protocol).
VAPID_SUBJECT=mailto:you@example.com

# Base URL of the web_auth service (used by middleware, /api/auth/me, and the client-side logout link).
# Public because the client needs it to build the logout URL. In local dev against XAMPP, override to something like
# http://localhost/web_auth/public
NEXT_PUBLIC_AUTH_BASE_URL=https://auth.andrewcromar.org
